using UnityEngine;
using TMPro;
using UnityEngine.UI;

public class InspectionManager : MonoBehaviour
{
    [Header("UI Elements")]
    [SerializeField] private TextMeshProUGUI DDE; 
    [SerializeField] private TextMeshProUGUI SEX;
    [SerializeField] private TextMeshProUGUI ISS;
    [SerializeField] private TextMeshProUGUI EXP;
    [SerializeField] private UIDraggableObject draggableDoc;
    [SerializeField] private GameObject victoryPanel;
    [SerializeField] private GameObject instructionsPanel;

    [Header("Character System")]
    [SerializeField] private Image visitorImageComponent; // Drag your 'Visitor_Character' object here
    [SerializeField] private Sprite[] characterSprites;

    [Header("Game State")]
    private bool isGameActive = false;
    private bool isCurrentDocValid = true; 
    private int correctChoicesCount = 0;
    private int targetScore = 3; 

    // Pools for Random Character Generation
    private string[] genders = { "M", "F" };
    private string[] cities = { "RIYADH", "NEOM", "JIDDAH", "DAMMAM" };
    private string[] invalidCities = { "UNKNOWN_ZONE", "ERROR_CITY", "VOID_CITY" };

    private void Start()
    {
        victoryPanel.SetActive(false);
        instructionsPanel.SetActive(true);
        ClearTextFields();
        
    }
    public void StartGame()
    {
        instructionsPanel.SetActive(false); // Hide the rule sheet
        isGameActive = true;                // Enable processing logic
        LoadNextDocument();                 // Slide in the first paper
    }
    private void ClearTextFields()
    {
        DDE.text = "";
        SEX.text = "";
        ISS.text = "";
        EXP.text = "";
    }

    private void LoadNextDocument()
    {

        if (!isGameActive) return;

        // 🌟 NEW: Pick a random character sprite and display it in the frame!
        if (characterSprites.Length > 0 && visitorImageComponent != null)
        {
            int randomCharacterIndex = Random.Range(0, characterSprites.Length);
            visitorImageComponent.sprite = characterSprites[randomCharacterIndex];

            // 🌟 ADD THIS LINE: This forces Unity to instantly reset the bounding box 
            // to match the exact raw pixel dimensions of this specific character!
            visitorImageComponent.SetNativeSize(); 
        }
        
        // 50% chance to generate a completely valid or invalid passport
        isCurrentDocValid = (Random.value > 0.5f);

        // Generate matching or scrambled random data
        string randomSex = genders[Random.Range(0, genders.Length)];
        
        if (isCurrentDocValid)
        {
            // Valid Document Data Setup
            DDE.text =  Random.Range(1985, 2008) + "/0" + Random.Range(1, 9) + "/" + Random.Range(10, 28);
            SEX.text =  randomSex;
            ISS.text =  cities[Random.Range(0, cities.Length)];
            EXP.text = " 2030/12/31"; // Valid expiration year
        }
        else
        {
            // Invalid Document Data Setup (Randomly cause a discrepancy)
            int flawType = Random.Range(0, 2);

            if (flawType == 0)
            {
                // Flaw: Document is expired
                EXP.text =  Random.Range(2020, 2025) + "/05/12"; 
                ISS.text =  cities[Random.Range(0, cities.Length)];
            }
            else
            {
                // Flaw: Unrecognized fake issuing location
                EXP.text = "2030/12/31";
                ISS.text = invalidCities[Random.Range(0, invalidCities.Length)];
            }

            DDE.text = Random.Range(1985, 2008) + "/02/" + Random.Range(10, 28);
            SEX.text = randomSex;
        }
    }

    public void ProcessApprove()
    {
        if (!isGameActive) return;

        if (draggableDoc.currentStampZone != "Stamp_Approve")
        {
            Debug.Log("Cannot stamp! No document in the Approve zone.");
            return;
        }

        if (isCurrentDocValid)
        {
            Debug.Log("Correct Entry Allowed!");
            correctChoicesCount++;
        }
        else
        {
            Debug.Log("Mistake! You allowed an invalid passport!");
        }

        CheckWinCondition();
    }

    public void ProcessDeny()
    {
        if (!isGameActive) return;
        if (draggableDoc.currentStampZone != "Stamp_Deny")
        {
            Debug.Log("Cannot stamp! No document in the Deny zone.");
            return;
        }

        if (!isCurrentDocValid)
        {
            Debug.Log("Correct Entry Blocked!");
            correctChoicesCount++;
        }
        else
        {
            Debug.Log("Mistake! You blocked a valid visitor!");
        }

        CheckWinCondition();
    }

    private void CheckWinCondition()
    {
        if (correctChoicesCount >= targetScore)
        {
            isGameActive = false;
            victoryPanel.SetActive(true);
            Debug.Log("Zone Cleared!");
        }
        else
        {
            LoadNextDocument();
        }
    }
}